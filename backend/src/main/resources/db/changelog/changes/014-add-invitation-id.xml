<?xml version="1.0" encoding="UTF-8"?>
<databaseChangeLog
        xmlns="http://www.liquibase.org/xml/ns/dbchangelog"
        xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance"
        xsi:schemaLocation="http://www.liquibase.org/xml/ns/dbchangelog
        http://www.liquibase.org/xml/ns/dbchangelog/dbchangelog-latest.xsd">

    <changeSet id="014-1" author="phase5">
        <preConditions onFail="MARK_RAN">
            <not>
                <columnExists tableName="memberships" columnName="invitation_id"/>
            </not>
        </preConditions>
        <comment>Add invitation_id and status columns to memberships (may already exist from 013-add-invited-membership-support)</comment>
        <addColumn tableName="memberships">
            <column name="invitation_id" type="UUID">
                <constraints nullable="true"/>
            </column>
            <column name="status" type="VARCHAR(20)" defaultValue="ACTIVE">
                <constraints nullable="false"/>
            </column>
        </addColumn>
    </changeSet>

</databaseChangeLog>

<?xml version="1.0" encoding="UTF-8"?>
<databaseChangeLog
        xmlns="http://www.liquibase.org/xml/ns/dbchangelog"
        xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance"
        xsi:schemaLocation="http://www.liquibase.org/xml/ns/dbchangelog
        http://www.liquibase.org/xml/ns/dbchangelog/dbchangelog-latest.xsd">

    <changeSet id="001" author="goaldone">
        <validCheckSum>8:any</validCheckSum>
        <createTable tableName="organizations">
            <column name="id" type="UUID">
                <constraints primaryKey="true" nullable="false"/>
            </column>
            <column name="zitadel_org_id" type="VARCHAR(64)">
                <constraints nullable="false" unique="true" uniqueConstraintName="uq_organizations_zitadel_org_id"/>
            </column>
            <column name="name" type="VARCHAR(255)">
                <constraints nullable="false"/>
            </column>
            <column name="created_at" type="TIMESTAMP" defaultValueComputed="NOW()">
                <constraints nullable="false"/>
            </column>
        </createTable>

        <createTable tableName="users">
            <column name="id" type="UUID">
                <constraints primaryKey="true" nullable="false"/>
            </column>
            <column name="zitadel_sub" type="VARCHAR(64)">
                <constraints nullable="false" unique="true" uniqueConstraintName="uq_user_accounts_auth_user_id"/>
            </column>
            <column name="organization_id" type="UUID">
                <constraints nullable="false" foreignKeyName="fk_users_org" references="organizations(id)"/>
            </column>
            <column name="email" type="VARCHAR(255)">
                <constraints nullable="false"/>
            </column>
            <column name="first_name" type="VARCHAR(255)"/>
            <column name="last_name" type="VARCHAR(255)"/>
            <column name="created_at" type="TIMESTAMP" defaultValueComputed="NOW()">
                <constraints nullable="false"/>
            </column>
            <column name="last_seen_at" type="TIMESTAMP"/>
        </createTable>

        <addUniqueConstraint tableName="users" columnNames="organization_id, email" constraintName="uq_users_org_email"/>
        <createIndex tableName="users" indexName="idx_users_org">
            <column name="organization_id"/>
        </createIndex>
    </changeSet>

</databaseChangeLog>

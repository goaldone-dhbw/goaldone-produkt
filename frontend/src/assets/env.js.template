(function(window) {
  window.__env = {
    // Auth-Service OAuth2/OIDC Client ID
    // Set via environment variable: OIDC_CLIENT_ID (matches docker-compose env var name)
    // Local dev: 'goaldone-frontend'
    // Production: Registered client ID in auth-service JDBC registry
    clientId: '${OIDC_CLIENT_ID:-goaldone-frontend}',

    // Auth-Service OAuth2/OIDC Issuer URI (discovery document endpoint)
    // Set via environment variable: OIDC_ISSUER_URI (matches docker-compose env var name)
    // Local dev: 'http://localhost:9000'
    // Dev: 'https://auth.dev.goaldone.de'
    // Production: 'https://auth.goaldone.de'
    issuerUri: '${OIDC_ISSUER_URI:-http://localhost:9000}',

    // Backend API Base Path (optional, defaults to http://localhost:8080/api/v1)
    // Set via environment variable: API_BASE_PATH
    // Local dev: 'http://localhost:8080/api/v1'
    // Production: '/api/v1' (if reverse-proxied) or 'https://api.goaldone.de'
    apiBasePath: '${API_BASE_PATH:-http://localhost:8080/api/v1}',
  };
})(window);

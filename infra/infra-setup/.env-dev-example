# ============================================================
# ZITADEL + Traefik — DEVELOPMENT Environment Configuration
# ============================================================
# Copy this file to .env-dev and adjust the values below.
#
#   cp .env-dev-example .env-dev
#
# Then generate secure secrets:
#
#   ZITADEL_MASTERKEY=$(tr -dc A-Za-z0-9 </dev/urandom | head -c 32)
#   POSTGRES_ADMIN_PASSWORD=$(tr -dc A-Za-z0-9 </dev/urandom | head -c 32)
#   POSTGRES_ZITADEL_PASSWORD=$(tr -dc A-Za-z0-9 </dev/urandom | head -c 32)
#
# Start:
#   docker compose -f docker-compose.dev.yml --env-file .env-dev up -d --wait
#
# Login at:
#   https://sso.dev.goaldone.de/ui/console
# ============================================================

# -----------------------------
# Domain and external URL (DEV)
# -----------------------------
ZITADEL_DOMAIN=sso.dev.goaldone.de
ZITADEL_EXTERNALPORT=443
ZITADEL_EXTERNALSECURE=true

# -----------------------------
# Let's Encrypt
# -----------------------------
LETSENCRYPT_EMAIL=admin@goaldone.de

# -----------------------------
# Security / bootstrap
# -----------------------------
# Must be exactly 32 characters.
ZITADEL_MASTERKEY=MasterkeyNeedsToHave32Characters

# Login client PAT expiration (far future)
LOGIN_CLIENT_PAT_EXPIRATION=2099-01-01T00:00:00Z

# -----------------------------
# First instance admin user (DEV)
# (only applied on first start)
# -----------------------------
ZITADEL_ORG_NAME=GoalDone-Dev
ZITADEL_ADMIN_USERNAME=admin
ZITADEL_ADMIN_PASSWORD=devPass123
ZITADEL_ADMIN_EMAIL=admin@goaldone.de

# -----------------------------
# Pinned image tags
# -----------------------------
ZITADEL_VERSION=v4.11.0
TRAEFIK_IMAGE=traefik:v3.6.8
POSTGRES_IMAGE=postgres:17.2-alpine

# -----------------------------
# PostgreSQL (DEV)
# -----------------------------
POSTGRES_DB=zitadel_dev
POSTGRES_ADMIN_USER=postgres
POSTGRES_ADMIN_PASSWORD=dev_postgres_admin_password
POSTGRES_ZITADEL_USER=zitadel_dev
POSTGRES_ZITADEL_PASSWORD=dev_zitadel_db_password

# -----------------------------
# Access logs
# -----------------------------
ZITADEL_ACCESS_LOG_STDOUT_ENABLED=true

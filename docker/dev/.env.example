# Application versions
BACKEND_VERSION=0.0.1
FRONTEND_VERSION=0.0.1

# Database
POSTGRES_PASSWORD=changeme

# ============================================================================
# Auth-Service Configuration
# Note: All services authenticate against auth-service OIDC endpoint
# Backend validates JWT from AUTH_SERVICE_JWT_ISSUER_URI
# Frontend exchanges auth code at AUTH_SERVICE_JWT_ISSUER_URI
# ============================================================================
AUTH_SERVICE_VERSION=0.0.1
AUTH_SERVICE_DB_HOST=postgres-auth-dev
AUTH_SERVICE_DB_PORT=5432
AUTH_SERVICE_DB_NAME=auth_service
AUTH_SERVICE_DB_USER=auth_service
AUTH_SERVICE_DB_PASSWORD=changeme
AUTH_SERVICE_RSA_PRIVATE_KEY=YOUR_RSA_PRIVATE_KEY_BASE64_OR_PEM
AUTH_SERVICE_JWT_ISSUER_URI=http://auth-service-dev:9000

# Frontend OIDC client registered in auth-service
FRONTEND_CLIENT_ID=YOUR_FRONTEND_CLIENT_ID

# Blue-green deployment
FRONTEND_BLUE_ACTIVE=true
FRONTEND_GREEN_ACTIVE=false
ACTIVE_COLOR=blue
